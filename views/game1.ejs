<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
        integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N" crossorigin="anonymous" />
    <link rel="stylesheet" href="./css/light.css">
    <style>
        .bac {
            display: flex !important;
            align-items: center;
        }
        
        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateX(-100px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        .fade {
            animation: fadeIn 0.3s ease-out forwards;
        }
    </style>
    <title>Minijuegos</title>
</head>
<body>
    <div class="container fade">
        <br>
        <div class="bac">
            <a href="/dashboard?id=<%= id %>" class="btn btn-dark">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <span style="margin-left: 5px;">Volver</span>
        </div>
        <br>
        <center>
            <h1 class="display-4">Minijuegos</h1>
            <hr>
        </center>
        <br><br>
        
        <div class="alert alert-dark" role="alert">
            <center>
                <span class="material-symbols-outlined" style="font-size: 40px;">stadia_controller</span>
                <br><br>
                <strong>Selecciona un juego</strong>
            </center>
        </div>
        
        <div class="alert alert-dark" role="alert">
            <a class="btn btn-dark" href="/dashboard/game/1?id=<%= id %>" role="button">
                <span class="material-symbols-outlined">grid_view</span>
            </a>
            <span style="margin-left: 2px;">Tower Blocks</span>
            <br><br>
            <a class="btn btn-dark" href="/dashboard/game/2?id=<%= id %>" role="button">
                <span class="material-symbols-outlined">flutter_dash</span>
            </a>
            <span style="margin-left: 2px;">Flappy Bird 3D</span>
        </div>
        
        <% if(typeof cuest !== 'undefined' && cuest !== null) { %>
        <div class="alert alert-dark" role="alert">
            <center>
                <span>Intentos disponibles: <strong><%= cuest - 2 %></strong></span>
            </center>
        </div>
        <% } %>
        
    </div>
</body>
</html>
