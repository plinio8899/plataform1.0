<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Flappy Bird 3D</title>
  <link rel="stylesheet" href="/css/game.css">
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
  <link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
  crossorigin="anonymous"
  />
</head>
<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateX(100px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .fade {
    animation: fadeIn 0.3s ease-out forwards;
  }
</style>
<body>
<meta name="viewport" content="width=device-width,user-scalable=no">
<% if(cuest <= 1){ %>
  <div class="container fade">
    <br>
    <div class="bac">
      <a class="btn btn-dark" href="/dashboard/game1?id=<%= id %>">
        <span class="material-symbols-outlined">arrow_back</span>
      </a>
    </div>
    <br>
    <center>
      <h1 class="display-4">No tienes intentos</h1>
      <hr>
    </center>
    <br><br>
    <div class="alert alert-dark" role="alert">
      <center>
        <span>Los intentos se recargan todos los dias</span>
      </center>
    </div>
  </div>
<% } else { %>

<div id="container-flappy">
  <div id="game-flappy"></div>
  <div id="score-flappy">0</div>
  <div id="instructions-flappy">Click or Spacebar to Flap</div>
  <div id="game-over-flappy" class="game-over-flappy">
    <h2>Game Over!</h2>
    <p>Score: <span id="final-score">0</span></p>
    <a id="return-button-flappy" style="z-index: 99999;" class="btn btn-light" href="#" role="button">Subir puntos</a>
    <br><br>
    <a id="retry-button-flappy" style="z-index: 99999;" class="btn btn-warning" href="#" role="button">Reintentar</a>
  </div>
  <div class="game-ready-flappy">
    <div id="start-button-flappy">
      <a class="btn-dark" href="/dashboard/game1?id=<%= id %>" style="z-index: 99999;">
        <span class="material-symbols-outlined">arrow_back</span>
      </a>
    </div>
    <div></div>
    <br>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const returnButton = document.getElementById('return-button-flappy');
    if (returnButton) {
      returnButton.addEventListener('click', () => {
        const score = document.getElementById('final-score');
        if (score) {
          const gameNumber = score.textContent;
          window.location.href = `/dashboard/gamepoints?id=<%= id %>&points=${gameNumber}&gameId=2`;
        }
      });
    }

    const retryButton = document.getElementById('retry-button-flappy');
    if (retryButton) {
      retryButton.addEventListener('click', () => {
        location.reload();
      });
    }
  });
</script>
  
<script src='https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js'></script>
<script src="/js/script-flappy.js"></script>

<% } %>
</body>
</html>
