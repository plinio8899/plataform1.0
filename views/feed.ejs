<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="kVK4n2UxORHkEt0uBIOV7HvBKH20dyDSZz6lkbSU90M" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
        integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N"
        crossorigin="anonymous"
    />
    <link rel="stylesheet" href="./css/light.css">
    <style>
        .bac {
            display: flex !important;
            align-items: center;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade {
            animation: fadeIn 0.4s ease-out forwards;
        }

        .post-card {
            animation: fadeIn 0.4s ease-out forwards;
            margin-bottom: 1rem;
        }

        .post-card:nth-child(1) { animation-delay: 0.1s; }
        .post-card:nth-child(2) { animation-delay: 0.2s; }
        .post-card:nth-child(3) { animation-delay: 0.3s; }
        .post-card:nth-child(4) { animation-delay: 0.4s; }
        .post-card:nth-child(5) { animation-delay: 0.5s; }

        .autor-badge {
            font-size: 0.85rem;
            padding: 2px 8px;
            border-radius: 12px;
        }

        .reaction-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 5px 10px;
            border-radius: 20px;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .reaction-btn:hover {
            background-color: rgba(220, 53, 69, 0.1);
        }

        .reaction-btn.liked {
            color: #dc3545;
        }

        .reaction-btn.liked .heart-icon {
            fill: #dc3545;
        }

        .comment-section {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #e9ecef;
        }

        .comment {
            background-color: #f8f9fa;
            border-radius: 10px;
            padding: 10px;
            margin-bottom: 10px;
        }

        .comment-author {
            font-weight: 600;
            font-size: 0.85rem;
            color: #343a40;
        }

        .comment-content {
            margin-top: 5px;
            font-size: 0.9rem;
        }

        .comment-form {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .comment-input {
            flex: 1;
            border-radius: 20px;
            padding: 8px 15px;
            border: 1px solid #ced4da;
        }

        .comment-input:focus {
            border-color: #343a40;
            box-shadow: none;
        }

        .toggle-comments {
            cursor: pointer;
            color: #6c757d;
            font-size: 0.9rem;
        }

        .toggle-comments:hover {
            color: #343a40;
        }
    </style>
    <title>Feed - Estados</title>
</head>
<body>
    <div class="container fade">
        <div class="bac">
            <a class="btn btn-dark" href="/dashboard?id=<%= id %>" style="margin-top: 1em;">
                <span class="material-symbols-outlined">arrow_back</span>
            </a>
            <span style="margin-left: 10px; margin-top: 1em; font-size: 1.2rem;">
                <strong>Estados</strong>
            </span>
        </div>
        <br>
        <center>
            <h1 class="display-4">Estados</h1>
            <hr>
        </center>

        <!-- Formulario para crear post -->
        <div class="card mb-4">
            <div class="card-body">
                <form action="/feed?id=<%= id %>" method="POST">
                    <div class="form-group">
                        <label for="description"><strong>¿Qué estás pensando?</strong></label>
                        <textarea 
                            class="form-control" 
                            id="description" 
                            name="description" 
                            rows="3" 
                            placeholder="Escribe tu estado aquí..."
                            required
                        ></textarea>
                    </div>
                    <button type="submit" class="btn btn-dark">
                        <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle;">
                            send
                        </span>
                        Publicar
                    </button>
                </form>
            </div>
        </div>

        <!-- Lista de posts -->
        <% if (posts && posts.length > 0) { %>
            <% posts.forEach(function(post, index) { %>
                <% 
                    // Check if current user has liked this post
                    const userReaction = post.reactions.find(r => r.userId === id);
                    const reactionCount = post._count.reactions;
                    const commentCount = post._count.comments;
                %>
                <div class="card post-card" style="opacity: 0;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge badge-dark autor-badge">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">
                                        person
                                    </span>
                                    <%= post.author ? post.author.name : 'Usuario desconocido' %>
                                </span>
                                <% if (post.author && post.author.rango) { %>
                                    <span class="badge badge-secondary autor-badge">
                                        <%= post.author.rango %>
                                    </span>
                                <% } %>
                            </div>
                            <small class="text-muted"><%= new Date(post.createdAt).toLocaleDateString() %></small>
                        </div>
                        <hr>
                        <p class="card-text mt-2" style="white-space: pre-wrap;"><%= post.description %></p>
                        
                        <!-- Reactions and Comments Section -->
                        <div class="d-flex align-items-center justify-content-between mt-3">
                            <div class="d-flex align-items-center">
                                <!-- Like Button -->
                                <form action="/feed/reaction?id=<%= id %>&postId=<%= post.id %>" method="POST" style="display: inline;">
                                    <button type="submit" class="reaction-btn <%= userReaction ? 'liked' : '' %>">
                                        <span class="material-symbols-outlined heart-icon" style="font-size: 1.3rem;">
                                            favorite
                                        </span>
                                        <span><%= reactionCount %></span>
                                    </button>
                                </form>
                                
                                <!-- Toggle Comments -->
                                <button type="button" class="reaction-btn toggle-comments" onclick="toggleComments(<%= post.id %>)">
                                    <span class="material-symbols-outlined" style="font-size: 1.3rem;">
                                        chat_bubble
                                    </span>
                                    <span><%= commentCount %></span>
                                </button>
                            </div>
                        </div>

                        <!-- Comments Section (Hidden by default) -->
                        <div id="comments-<%= post.id %>" class="comment-section" style="display: none;">
                            <!-- Comments List -->
                            <% if (post.comments && post.comments.length > 0) { %>
                                <% post.comments.forEach(function(comment) { %>
                                    <div class="comment">
                                        <span class="comment-author">
                                            <span class="material-symbols-outlined" style="font-size: 0.9rem; vertical-align: middle;">
                                                person
                                            </span>
                                            <%= comment.user ? comment.user.name : 'Usuario' %>
                                            <% if (comment.user && comment.user.rango) { %>
                                                <small class="text-muted">• <%= comment.user.rango %></small>
                                            <% } %>
                                        </span>
                                        <p class="comment-content mb-0"><%= comment.content %></p>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <p class="text-muted" style="font-size: 0.85rem;">No hay comentarios todavía.</p>
                            <% } %>
                            
                            <!-- Comment Form -->
                            <form action="/feed/comment?id=<%= id %>&postId=<%= post.id %>" method="POST" class="comment-form">
                                <input type="text" name="comment" class="comment-input" placeholder="Escribe un comentario..." required>
                                <button type="submit" class="btn btn-dark btn-sm">
                                    <span class="material-symbols-outlined" style="font-size: 1rem;">
                                        send
                                    </span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="alert alert-secondary text-center" role="alert">
                <span class="material-symbols-outlined" style="font-size: 3rem; display: block; margin-bottom: 10px;">
                    feed
                </span>
                <p class="mb-0">No hay publicaciones todavía.</p>
                <p class="text-muted">¡Sé el primero en publicar algo!</p>
            </div>
        <% } %>
        <br><br>
    </div>

    <script>
        function toggleComments(postId) {
            const section = document.getElementById('comments-' + postId);
            if (section.style.display === 'none') {
                section.style.display = 'block';
            } else {
                section.style.display = 'none';
            }
        }
    </script>
</body>
</html>
