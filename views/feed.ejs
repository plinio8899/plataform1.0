<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="google-site-verification" content="kVK4n2UxORHkEt0uBIOV7HvBKH20dyDSZz6lkbSU90M" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link
        rel="stylesheet"
        href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css"
        integrity="sha384-xOolHFLEh07PJGoPkLv1IbcEPTNtaed2xpHsD9ESMhqIYd0nLMwNLD69Npy4HI+N"
        crossorigin="anonymous"
    />
    <link rel="stylesheet" href="./css/light.css">
    <style>
        .bac {
            display: flex !important;
            align-items: center;
            justify-content: space-between;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .fade {
            animation: fadeIn 0.4s ease-out forwards;
        }

        .post-card {
            animation: fadeIn 0.4s ease-out forwards;
            margin-bottom: 1rem;
        }

        .post-card:nth-child(1) { animation-delay: 0.1s; }
        .post-card:nth-child(2) { animation-delay: 0.2s; }
        .post-card:nth-child(3) { animation-delay: 0.3s; }
        .post-card:nth-child(4) { animation-delay: 0.4s; }
        .post-card:nth-child(5) { animation-delay: 0.5s; }

        .autor-badge {
            font-size: 0.85rem;
            padding: 2px 8px;
            border-radius: 12px;
        }

        .reaction-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 5px 10px;
            border-radius: 20px;
            transition: all 0.2s ease;
            display: inline-flex;
            align-items: center;
            gap: 5px;
        }

        .reaction-btn:hover {
            background-color: rgba(220, 53, 69, 0.1);
        }

        .reaction-btn.liked {
            color: #dc3545;
        }

        .reaction-btn.liked .heart-icon {
            fill: #dc3545;
        }

        .comment-section {
            margin-top: 15px;
            padding-top: 15px;
            border-top: 1px solid #e9ecef;
        }

        .comment {
            background-color: #f8f9fa;
            border-radius: 10px;
            padding: 10px;
            margin-bottom: 10px;
        }

        .comment-author {
            font-weight: 600;
            font-size: 0.85rem;
            color: #343a40;
        }

        .comment-content {
            margin-top: 5px;
            font-size: 0.9rem;
        }

        .comment-form {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .comment-input {
            flex: 1;
            border-radius: 20px;
            padding: 8px 15px;
            border: 1px solid #ced4da;
        }

        .comment-input:focus {
            border-color: #343a40;
            box-shadow: none;
        }

        .toggle-comments {
            cursor: pointer;
            color: #6c757d;
            font-size: 0.9rem;
        }

        .toggle-comments:hover {
            color: #343a40;
        }

        .post-actions {
            opacity: 0;
            transition: opacity 0.2s ease;
        }

        .post-card:hover .post-actions {
            opacity: 1;
        }

        .action-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 5px 8px;
            border-radius: 5px;
            transition: all 0.2s ease;
            color: #6c757d;
        }

        .action-btn:hover {
            background-color: rgba(0,0,0,0.1);
        }

        .action-btn.edit-btn:hover {
            color: #007bff;
            background-color: rgba(0,123,255,0.1);
        }

        .action-btn.delete-btn:hover {
            color: #dc3545;
            background-color: rgba(220,53,69,0.1);
        }

        .edit-form {
            display: none;
        }

        .edit-form.active {
            display: block;
        }

        .original-text {
            display: block;
        }

        .original-text.hidden {
            display: none;
        }

        .edit-textarea {
            width: 100%;
            border: 2px solid #343a40;
            border-radius: 8px;
            padding: 10px;
            font-family: inherit;
            resize: vertical;
            min-height: 80px;
        }

        .edit-actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .btn-cancel {
            background-color: #6c757d;
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 5px;
            cursor: pointer;
        }

        .btn-cancel:hover {
            background-color: #5a6268;
        }

        /* Emoji Picker Styles */
        .emoji-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px 12px;
            border-radius: 50%;
            transition: all 0.2s ease;
            color: #6c757d;
            position: relative;
        }

        .emoji-btn:hover {
            background-color: rgba(0,0,0,0.1);
            color: #343a40;
        }

        .emoji-picker {
            position: absolute;
            bottom: 50px;
            right: 0;
            background: white;
            border: 1px solid #dee2e6;
            border-radius: 12px;
            box-shadow: 0 5px 20px rgba(0,0,0,0.15);
            padding: 12px;
            z-index: 1000;
            display: none;
            max-width: 320px;
            animation: fadeIn 0.2s ease-out;
        }

        .emoji-picker.active {
            display: block;
        }

        .emoji-grid {
            display: grid;
            grid-template-columns: repeat(8, 1fr);
            gap: 4px;
            max-height: 200px;
            overflow-y: auto;
        }

        .emoji-item {
            font-size: 1.4rem;
            padding: 6px;
            cursor: pointer;
            border-radius: 6px;
            transition: background-color 0.15s ease;
            text-align: center;
            background: none;
            border: none;
        }

        .emoji-item:hover {
            background-color: #f1f3f5;
            transform: scale(1.2);
        }

        .input-group-with-emoji {
            position: relative;
            display: flex;
            align-items: flex-end;
            gap: 8px;
        }

        .form-group .input-group-with-emoji {
            margin-bottom: 0;
        }

        .input-group-with-emoji textarea {
            flex: 1;
            margin-bottom: 0;
        }

        /* Floating Action Button - Header Style */
        .fab-button {
            width: auto !important;
            height: 38px !important;
            padding: 0 16px !important;
            border-radius: 4px !important;
            background-color: #343a40 !important;
            color: white !important;
            border: none !important;
            cursor: pointer !important;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1) !important;
            display: flex !important;
            align-items: center !important;
            justify-content: center !important;
            margin: 0 !important;
            margin-top: 1em !important;
        }

        .fab-button:hover {
            transform: scale(1.1);
            box-shadow: 0 6px 20px rgba(0,0,0,0.4);
        }

        .fab-button.active {
            transform: rotate(45deg);
            background-color: #dc3545;
        }

        .fab-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: rgba(0,0,0,0.5);
            z-index: 1040;
            display: none;
            backdrop-filter: blur(2px);
            animation: fadeIn 0.2s ease-out;
        }

        .fab-overlay.active {
            display: block;
        }

        .fab-form-container {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: white;
            border-radius: 20px 20px 0 0;
            padding: 24px;
            padding-bottom: calc(100px + env(safe-area-inset-bottom, 0px));
            z-index: 100000 !important;
            transform: translateY(100%);
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            box-shadow: 0 -4px 20px rgba(0,0,0,0.15);
        }

        .fab-form-container.active {
            transform: translateY(0);
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }

        /* Notifications Panel */
        .notification-panel {
            position: absolute;
            top: 80px;
            right: 0;
            width: 350px;
            max-height: 400px;
            background: white;
            border-radius: 12px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.2);
            z-index: 1000;
            display: none;
            overflow-y: auto;
            overflow-x: hidden;
        }

        .notification-panel.active {
            display: block;
            animation: fadeIn 0.2s ease-out;
        }

        .notification-item {
            padding: 12px 16px;
            border-bottom: 1px solid #f1f3f5;
            cursor: pointer;
            transition: background-color 0.15s ease;
        }

        .notification-item:hover {
            background-color: #f8f9fa;
        }

        .notification-title {
            font-weight: 600;
            font-size: 0.9rem;
            margin-bottom: 4px;
        }

        .notification-text {
            font-size: 0.85rem;
            color: #6c757d;
            margin-bottom: 4px;
        }

        .notification-time {
            font-size: 0.75rem;
            color: #adb5bd;
        }

        @media (min-width: 768px) {
            .fab-form-container {
                max-width: 500px;
                margin: 0 auto;
                bottom: 0;
                border-radius: 16px 16px 0 0;
            }
        }
    </style>
    <title>Feed - Estados</title>
</head>
<body>
    <div class="container fade">
        <div class="bac">
            <div style="display: flex; align-items: center;">
                <a class="btn btn-dark" href="/dashboard?id=<%= id %>" style="margin-top: 1em;">
                    <span class="material-symbols-outlined">arrow_back</span>
                </a>
                <span style="margin-left: 10px; margin-top: 1em; font-size: 1.2rem;">
                    <strong>Estados</strong>
                </span>
            </div>
            <div style="display: flex; gap: 10px; align-items: center;">
                <button class="fab-button btn btn-dark" id="notificationBtn" onclick="toggleNotificationPanel()">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <button class="fab-button btn btn-dark" id="fabBtn" onclick="toggleFabForm()">
                    <span class="material-symbols-outlined">add</span>
                </button>
            </div>
        </div>
        <br>
        <center>
            <h1 class="display-4">Estados</h1>
            <hr>
        </center>



        <!-- Lista de posts -->
        <div class="posts-container">
        <% if (posts && posts.length > 0) { %>
            <% posts.forEach(function(post, index) { %>
                <% 
                    // Check if current user has liked this post
                    const userReaction = post.reactions.find(r => r.userId === id);
                    const reactionCount = post._count.reactions;
                    const commentCount = post._count.comments;
                %>
                <div class="card post-card" data-post-id="<%= post.id %>" style="opacity: 0;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge badge-dark autor-badge">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">
                                        person
                                    </span>
                                    <%= post.author ? post.author.name : 'Usuario desconocido' %>
                                </span>
                                <% if (post.author && post.author.rango) { %>
                                    <span class="badge badge-secondary autor-badge">
                                        <%- post.author.rango %>
                                    </span>
                                <% } %>
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                <% if (post.authorId === id) { %>
                                    <div class="post-actions d-flex gap-1">
                                        <button type="button" class="action-btn edit-btn" onclick="enableEdit(<%= post.id %>)" title="Editar">
                                            <span class="material-symbols-outlined" style="font-size: 1.2rem;">edit</span>
                                        </button>
                                        <form action="/feed/delete?id=<%= id %>&postId=<%= post.id %>" method="POST" style="display: inline;">
                                            <button type="submit" class="action-btn delete-btn" onclick="return confirm('¬њEliminar esta publicaci√≥n?')" title="Eliminar">
                                                <span class="material-symbols-outlined" style="font-size: 1.2rem;">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                <% } %>
                                <small class="text-muted"><%= new Date(post.createdAt).toLocaleDateString() %></small>
                            </div>
                        </div>
                        <hr>
                        <p class="card-text mt-2 original-text" id="text-<%= post.id %>" style="white-space: pre-wrap;"><%= post.description %></p>
                        
                        <!-- Edit Form (Hidden by default) -->
                        <form action="/feed/update?id=<%= id %>&postId=<%= post.id %>" method="POST" class="edit-form" id="edit-form-<%= post.id %>">
                            <textarea name="description" class="edit-textarea" id="edit-textarea-<%= post.id %>"><%= post.description %></textarea>
                            <div class="edit-actions">
                                <button type="submit" class="btn btn-dark btn-sm">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">check</span>
                                    Guardar
                                </button>
                                <button type="button" class="btn-cancel" onclick="cancelEdit(<%= post.id %>)">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">close</span>
                                    Cancelar
                                </button>
                            </div>
                        </form>
                        
                        <!-- Reactions and Comments Section -->
                        <div class="d-flex align-items-center justify-content-between mt-3">
                            <div class="d-flex align-items-center">
                                <!-- Like Button -->
                                <form action="/feed/reaction?id=<%= id %>&postId=<%= post.id %>" method="POST" style="display: inline;">
                                    <button type="submit" class="reaction-btn <%= userReaction ? 'liked' : '' %>">
                                        <span class="material-symbols-outlined heart-icon" style="font-size: 1.3rem;">
                                            favorite
                                        </span>
                                        <span><%= reactionCount %></span>
                                    </button>
                                </form>
                                
                                <!-- Toggle Comments -->
                                <button type="button" class="reaction-btn toggle-comments" onclick="toggleComments(<%= post.id %>)">
                                    <span class="material-symbols-outlined" style="font-size: 1.3rem;">
                                        chat_bubble
                                    </span>
                                    <span><%= commentCount %></span>
                                </button>
                            </div>
                        </div>

                        <!-- Comments Section (Hidden by default) -->
                        <div id="comments-<%= post.id %>" class="comment-section" style="display: none;">
                            <!-- Comments List -->
                            <% if (post.comments && post.comments.length > 0) { %>
                                <% post.comments.forEach(function(comment) { %>
                                    <div class="comment">
                                        <span class="comment-author">
                                            <span class="material-symbols-outlined" style="font-size: 0.9rem; vertical-align: middle;">
                                                person
                                            </span>
                                            <%= comment.user ? comment.user.name : 'Usuario' %>
                                            <% if (comment.user && comment.user.rango) { %>
                                                <small class="text-muted">вАҐ <%= comment.user.rango %></small>
                                            <% } %>
                                        </span>
                                        <p class="comment-content mb-0"><%= comment.content %></p>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <p class="text-muted" style="font-size: 0.85rem;">No hay comentarios todav√≠a.</p>
                            <% } %>
                            
                            <!-- Comment Form -->
                            <form action="/feed/comment?id=<%= id %>&postId=<%= post.id %>" method="POST" class="comment-form">
                                <input type="text" name="comment" class="comment-input" placeholder="Escribe un comentario..." required>
                                <button type="submit" class="btn btn-dark btn-sm">
                                    <span class="material-symbols-outlined" style="font-size: 1rem;">
                                        send
                                    </span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            <% }); %>
        <% } else { %>
            <div class="alert alert-secondary text-center" role="alert">
                <span class="material-symbols-outlined" style="font-size: 3rem; display: block; margin-bottom: 10px;">
                    feed
                </span>
                <p class="mb-0">No hay publicaciones todav√≠a.</p>
                <p class="text-muted">¬°S√© el primero en publicar algo!</p>
            </div>
        <% } %>
        <br><br>
    </div>



    <!-- Notifications Panel -->
    <div class="notification-panel" id="notificationPanel">
        <div id="notificationList">
            <div style="padding: 32px; text-align: center; color: #6c757d;">
                <span class="material-symbols-outlined" style="font-size: 3rem; display: block; margin-bottom: 8px;">notifications_off</span>
                No hay notificaciones
            </div>
        </div>
    </div>

    <!-- Overlay Background -->
    <div class="fab-overlay" id="fabOverlay" onclick="toggleFabForm()"></div>

    <!-- Floating Form Container -->
    <div class="fab-form-container" id="fabFormContainer">
        <form action="/feed?id=<%= id %>" method="POST">
            <div class="form-group">
                <label for="fab-description"><strong>¬њQu√© est√°s pensando?</strong></label>
                <div class="input-group-with-emoji">
                    <textarea 
                        class="form-control" 
                        id="fab-description" 
                        name="description" 
                        rows="3" 
                        placeholder="Escribe tu estado aqu√≠..."
                        required
                    ></textarea>
                    <button type="button" class="emoji-btn" onclick="event.preventDefault(); event.stopPropagation(); toggleEmojiPicker('fab-description'); return false;">
                        <span class="material-symbols-outlined">sentiment_satisfied</span>
                        <div class="emoji-picker" id="emoji-picker-fab-description"></div>
                    </button>
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn btn-secondary flex-grow-1" onclick="toggleFabForm()">Cancelar</button>
                <button type="submit" class="btn btn-dark flex-grow-1">
                    <span class="material-symbols-outlined" style="font-size: 1.2rem; vertical-align: middle;">
                        send
                    </span>
                    Publicar
                </button>
            </div>
        </form>
    </div>

    <script>
        function toggleFabForm() {
            const btn = document.getElementById('fabBtn');
            const overlay = document.getElementById('fabOverlay');
            const container = document.getElementById('fabFormContainer');
            const textarea = document.getElementById('fab-description');
            
            btn.classList.toggle('active');
            overlay.classList.toggle('active');
            container.classList.toggle('active');
            
            if(container.classList.contains('active')) {
                setTimeout(() => textarea.focus(), 300);
            } else {
                textarea.value = '';
            }
        }

        // Emoji Picker Implementation
        const commonEmojis = ['рЯША','рЯШВ','рЯ•∞','рЯШН','рЯ§©','рЯШК','рЯШО','рЯ•≥','рЯШЗ','рЯ§Ч','рЯШЛ','рЯ§Ф','рЯШі','рЯ§§','рЯШМ','рЯЩВ','рЯШЙ','рЯШЬ','рЯ§™','рЯШ±','рЯШ≠','рЯШ§','рЯШ°','рЯ§ђ','рЯ•Ї','рЯШҐ','рЯЩД','рЯШђ','рЯШЈ','рЯ§Т','рЯСН','рЯСО','рЯСМ','вЬМпЄП','рЯ§Ю','рЯ§Э','вЭ§пЄП','рЯТФ','рЯТѓ','вЬ®','рЯФ•','рЯОЙ','рЯОК','рЯТ™','рЯЩП','рЯСП','рЯ§≤','рЯТ°','в≠Р','рЯМЯ','рЯТЂ','вЬЕ','вЭМ','вЪ†пЄП','рЯТА','рЯСї','рЯ§°','рЯОБ','рЯОВ','рЯНХ','рЯНФ','рЯМЃ','рЯН©','вШХ','рЯНЇ','рЯНЈ','рЯПЖ','вЪљ','рЯОЃ','рЯОµ','рЯУЄ','рЯТї','рЯУ±','вЬИпЄП','рЯЪЧ','рЯП†','рЯМО','вШАпЄП','рЯМЩ','в≠Р','рЯМИ','вЭДпЄП','рЯФ•','рЯТІ','рЯМК'];

        function insertEmojiAtCursor(textarea, emoji) {
            const start = textarea.selectionStart;
            const end = textarea.selectionEnd;
            const text = textarea.value;
            
            textarea.value = text.substring(0, start) + emoji + text.substring(end);
            textarea.selectionStart = textarea.selectionEnd = start + emoji.length;
            textarea.focus();
        }

        function toggleEmojiPicker(inputId, event) {
            if(event) {
                event.preventDefault();
                event.stopPropagation();
            }
            
            const picker = document.getElementById('emoji-picker-' + inputId);
            const allPickers = document.querySelectorAll('.emoji-picker');
            
            allPickers.forEach(p => {
                if (p !== picker) p.classList.remove('active');
            });
            
            picker.classList.toggle('active');
            
            if (picker.classList.contains('active') && picker.children.length === 0) {
                const grid = document.createElement('div');
                grid.className = 'emoji-grid';
                
                commonEmojis.forEach(emoji => {
                    const btn = document.createElement('button');
                    btn.className = 'emoji-item';
                    btn.textContent = emoji;
                    btn.type = 'button';
                    btn.onclick = (e) => {
                        e.preventDefault();
                        e.stopPropagation();
                        const textarea = document.getElementById(inputId);
                        insertEmojiAtCursor(textarea, emoji);
                        picker.classList.remove('active');
                        return false;
                    };
                    grid.appendChild(btn);
                });
                
                picker.appendChild(grid);
            }
            
            return false;
        }

        document.addEventListener('click', (e) => {
            if (!e.target.closest('.emoji-btn')) {
                document.querySelectorAll('.emoji-picker').forEach(p => p.classList.remove('active'));
            }
        });
        // SSE connection for real-time updates
        let eventSource;
        const currentUserId = <%= id %>;
        
        function connectSSE() {
            eventSource = new EventSource('/events');
            
            eventSource.addEventListener('feed', (e) => {
                const data = JSON.parse(e.data);
                handleFeedUpdate(data);
            });
            
            eventSource.addEventListener('connected', (e) => {
                console.log('Connected to real-time updates');
            });

            // вЬЕ NOTIFICACIONES: Listener agregado CORRECTAMENTE aqui dentro despues de crear eventSource
            eventSource.addEventListener('notification', (e) => {
                try {
                    const data = JSON.parse(e.data);
                    console.log('рЯУ© NOTIFICACION RECIBIDA:', data);
                    
                    // Solo mostrar notificaciones que son para mi
                    if(data.userId === currentUserId) {
                        console.log('рЯУ© NOTIFICACION PARA MI:', data);
                        addNotification(data);
                    }
                } catch(err) {
                    console.log('вЭМ Error parseando notificacion:', err, e.data);
                }
            });
            
            eventSource.onerror = () => {
                console.log('SSE connection lost, reconnecting...');
                setTimeout(connectSSE, 5000);
            };
        }
        
        function handleFeedUpdate(data) {
            const { action, post } = data;
            
            switch(action) {
                case 'created':
                    addNewPost(post);
                    break;
                case 'deleted':
                    removePost(post.postId);
                    break;
                case 'reaction':
                    updateReaction(post.postId, post.userId, post.action);
                    break;
                case 'updated':
                    updatePostText(post.postId, post.description);
                    break;
            }
        }
        
        function addNewPost(post) {
            const postsContainer = document.querySelector('.posts-container');
            if (!postsContainer) return;
            
            const postHtml = createPostHTML(post);
            postsContainer.insertAdjacentHTML('afterbegin', postHtml);
            animateNewPost();
        }
        
        function createPostHTML(post) {
            const isOwner = post.authorId === currentUserId;
            return `
                <div class="card post-card" data-post-id="${post.id}" style="opacity: 0; animation: fadeIn 0.4s ease-out forwards;">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start">
                            <div>
                                <span class="badge badge-dark autor-badge">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">person</span>
                                    ${post.author ? post.author.name : 'Usuario'}
                                </span>
                                ${post.author && post.author.rango ? `<span class="badge badge-secondary autor-badge">${post.author.rango}</span>` : ''}
                            </div>
                            <div class="d-flex align-items-center gap-2">
                                ${isOwner ? `
                                    <div class="post-actions d-flex gap-1">
                                        <button type="button" class="action-btn edit-btn" onclick="enableEdit(${post.id})" title="Editar">
                                            <span class="material-symbols-outlined" style="font-size: 1.2rem;">edit</span>
                                        </button>
                                        <form action="/feed/delete?id=${currentUserId}&postId=${post.id}" method="POST" style="display: inline;">
                                            <button type="submit" class="action-btn delete-btn" onclick="return confirm('¬њEliminar esta publicaci√≥n?')" title="Eliminar">
                                                <span class="material-symbols-outlined" style="font-size: 1.2rem;">delete</span>
                                            </button>
                                        </form>
                                    </div>
                                ` : ''}
                                <small class="text-muted">${new Date(post.createdAt).toLocaleDateString()}</small>
                            </div>
                        </div>
                        <hr>
                        <p class="card-text mt-2 original-text" id="text-${post.id}" style="white-space: pre-wrap;">${post.description}</p>
                        <form action="/feed/update?id=${currentUserId}&postId=${post.id}" method="POST" class="edit-form" id="edit-form-${post.id}">
                            <textarea name="description" class="edit-textarea" id="edit-textarea-${post.id}">${post.description}</textarea>
                            <div class="edit-actions">
                                <button type="submit" class="btn btn-dark btn-sm">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">check</span> Guardar
                                </button>
                                <button type="button" class="btn-cancel" onclick="cancelEdit(${post.id})">
                                    <span class="material-symbols-outlined" style="font-size: 1rem; vertical-align: middle;">close</span> Cancelar
                                </button>
                            </div>
                        </form>
                        <div class="d-flex align-items-center justify-content-between mt-3">
                            <div class="d-flex align-items-center">
                                <form action="/feed/reaction?id=${currentUserId}&postId=${post.id}" method="POST" style="display: inline;">
                                    <button type="submit" class="reaction-btn">
                                        <span class="material-symbols-outlined heart-icon" style="font-size: 1.3rem;">favorite</span>
                                        <span>${post._count ? post._count.reactions : 0}</span>
                                    </button>
                                </form>
                                <button type="button" class="reaction-btn toggle-comments" onclick="toggleComments(${post.id})">
                                    <span class="material-symbols-outlined" style="font-size: 1.3rem;">chat_bubble</span>
                                    <span>${post._count ? post._count.comments : 0}</span>
                                </button>
                            </div>
                        </div>
                        <div id="comments-${post.id}" class="comment-section" style="display: none;">
                            <p class="text-muted" style="font-size: 0.85rem;">No hay comentarios todav√≠a.</p>
                            <form action="/feed/comment?id=${currentUserId}&postId=${post.id}" method="POST" class="comment-form">
                                <input type="text" name="comment" class="comment-input" placeholder="Escribe un comentario..." required>
                                <button type="submit" class="btn btn-dark btn-sm">
                                    <span class="material-symbols-outlined" style="font-size: 1rem;">send</span>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            `;
        }
        
        function removePost(postId) {
            const postElement = document.querySelector(`.post-card[data-post-id="${postId}"]`);
            if (postElement) {
                postElement.style.animation = 'fadeOut 0.3s ease-out forwards';
                setTimeout(() => postElement.remove(), 300);
            }
        }
        
        function updateReaction(postId, userId, action) {
            const postElement = document.querySelector(`.post-card[data-post-id="${postId}"]`);
            if (!postElement) return;
            
            const likeBtn = postElement.querySelector('.reaction-btn');
            const likeCount = likeBtn.querySelector('span:last-child');
            let count = parseInt(likeCount.textContent);
            
            if (action === 'added') {
                likeBtn.classList.add('liked');
                likeCount.textContent = count + 1;
            } else {
                likeBtn.classList.remove('liked');
                likeCount.textContent = Math.max(0, count - 1);
            }
        }
        
        function updatePostText(postId, description) {
            const textElement = document.getElementById('text-' + postId);
            if (textElement) {
                textElement.textContent = description;
            }
            cancelEdit(postId);
        }
        
        function animateNewPost() {
            const firstCard = document.querySelector('.post-card');
            if (firstCard) {
                firstCard.style.opacity = '1';
            }
        }
        
        // Add CSS for fadeOut animation
        const style = document.createElement('style');
        style.textContent = `
            @keyframes fadeOut {
                from { opacity: 1; transform: translateY(0); }
                to { opacity: 0; transform: translateY(-20px); }
            }
        `;
        document.head.appendChild(style);
        
        // Initialize SSE connection
        connectSSE();

        function toggleNotificationPanel() {
            const panel = document.getElementById('notificationPanel');
            panel.classList.toggle('active');
        }

        // Close panel when clicking outside
        document.addEventListener('click', (e) => {
            if (!e.target.closest('#notificationBtn') && !e.target.closest('#notificationPanel')) {
                document.getElementById('notificationPanel').classList.remove('active');
            }
        });

        // вЬЕ Sistema de Notificaciones
        let notifications = JSON.parse(localStorage.getItem('notifications') || '[]');

        function renderNotifications() {
            const list = document.getElementById('notificationList');
            
            if(notifications.length === 0) {
                list.innerHTML = `
                    <div style="padding: 32px; text-align: center; color: #6c757d;">
                        <span class="material-symbols-outlined" style="font-size: 3rem; display: block; margin-bottom: 8px;">notifications_off</span>
                        No hay notificaciones
                    </div>
                `;
                return;
            }

            list.innerHTML = notifications.map(n => `
                <div class="notification-item" data-id="${n.id}">
                    <div class="notification-title">${n.type === 'like' ? 'вЭ§пЄП  Le dieron like' : 'рЯТђ  Nuevo comentario'}</div>
                    <div class="notification-text">${n.userName} ${n.type === 'like' ? 'le dio like a tu publicaci√≥n' : `coment√≥: "${n.commentText}"`}</div>
                    <div class="notification-time">${new Date(n.timestamp).toLocaleString()}</div>
                </div>
            `).reverse().join('');
        }

        function addNotification(data) {
            data.id = Date.now();
            notifications.unshift(data);
            
            // Guardar maximo 50 notificaciones
            if(notifications.length > 50) {
                notifications = notifications.slice(0, 50);
            }
            
            localStorage.setItem('notifications', JSON.stringify(notifications));
            renderNotifications();
        }



        // Initialize notifications on load
        renderNotifications();
        
        function toggleComments(postId) {
            const section = document.getElementById('comments-' + postId);
            if (section.style.display === 'none') {
                section.style.display = 'block';
            } else {
                section.style.display = 'none';
            }
        }

        function enableEdit(postId) {
            const textElement = document.getElementById('text-' + postId);
            textElement.classList.add('hidden');
            
            const formElement = document.getElementById('edit-form-' + postId);
            formElement.classList.add('active');
            
            const textarea = document.getElementById('edit-textarea-' + postId);
            textarea.focus();
        }

        function cancelEdit(postId) {
            const textElement = document.getElementById('text-' + postId);
            textElement.classList.remove('hidden');
            
            const formElement = document.getElementById('edit-form-' + postId);
            formElement.classList.remove('active');
        }
    </script>
</body>
</html>
