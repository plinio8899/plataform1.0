// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Users {
  id Int @id @default(autoincrement())
  phone String @unique
  password String
  name String
  points Int?
  cuesStatus Int?
  rango String?
  rol String?
  totalPoints Int?
  sexo String
  posts Feed[]
  reactions Reaction[]
  comments Comment[]
}

model Cuest {
  id Int @id @default(autoincrement())
  preg String
  op1 String
  op2 String
  op3 String
  op4 String
  repTrue String
  cuestPoints Int
}

model Points {
  id Int @id @default(autoincrement())
  man Int
  woman Int
}

model Sms {
  author Int @id
  content String
}

model Feed {
  id Int @id @default(autoincrement())
  authorId Int
  author Users @relation(fields: [authorId], references: [id])
  description String
  createdAt DateTime @default(now())
  reactions Reaction[]
  comments Comment[]
}

model Reaction {
  id Int @id @default(autoincrement())
  postId Int
  post Feed @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId Int
  user Users @relation(fields: [userId], references: [id])
  type String
  createdAt DateTime @default(now())
  
  @@unique([postId, userId])
}

model Comment {
  id Int @id @default(autoincrement())
  postId Int
  post Feed @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId Int
  user Users @relation(fields: [userId], references: [id])
  content String
  createdAt DateTime @default(now())
}

model Codes {
  code Int @id
}
